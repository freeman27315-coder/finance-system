DISCORD_TOKEN=put_your_discord_bot_token_here
GITHUB_TOKEN=ghp_your_token_here
GITHUB_REPO=freeman27315-coder/finance-system
# 可选：填上 Discord 服务器 ID（开发者模式右键服务器名复制 ID），让 Slash 命令立即生效
DISCORD_GUILD_ID=

# LLM 后端：cli = 用 Claude Max 订阅额度（推荐，零 API 费用）；api = 用 Anthropic API
LLM_BACKEND=cli
# CLI 模式下 claude 可执行文件路径（默认 "claude"）
CLAUDE_CLI=claude
# 仅 LLM_BACKEND=api 时需要
# ANTHROPIC_API_KEY=sk-ant-...

# 以下用于事件驱动 PR 自动审查
# GitHub webhook 共享密钥（与 GitHub 端配置一致）
WEBHOOK_SECRET=
# Discord #pm-reports webhook URL，自动审查结果会推送到此
PM_REPORT_WEBHOOK=
# Bot 内置 HTTP 服务监听端口（cloudflared 转发到此）
WEBHOOK_PORT=8081
