GITHUB_TOKEN=ghp_your_token_here
WEBHOOK_SECRET=your_webhook_secret_here
AGENT_LABEL=frontend
# gh CLI 完整路径，默认 "gh"；若 which gh 返回非标准路径则填入
# GH_PATH=/Users/yourname/bin/gh

# ===== 事件驱动激活命令 =====
# 收到 GitHub 事件后，agent 会执行这条命令启动 AI 编程助手开干
# 默认走 Claude Code CLI；如使用 codex/cursor 等其他工具，请改命令模板
# 占位符：{issue_number} {issue_title} {issue_url} {action_hint}
# AGENT_DISPATCH_CMD=claude -p "请认领并完成任务 #{issue_number}：{issue_title}..."

# ===== UTF-8 兜底 =====
LANG=en_US.UTF-8
LC_ALL=en_US.UTF-8
PYTHONUTF8=1
PYTHONIOENCODING=utf-8
