GITHUB_TOKEN=ghp_your_token_here
WEBHOOK_SECRET=your_webhook_secret_here
AGENT_LABEL=backend
# gh CLI 完整路径，默认 "gh"；若 which gh 返回非标准路径则填入
# GH_PATH=/Users/yourname/bin/gh
# cloudflared 完整路径，默认 "cloudflared"；若 which cloudflared 找不到则填入
# CLOUDFLARED_PATH=/Users/yourname/bin/cloudflared

# ===== 事件驱动激活方式 =====
# 收到 GitHub 事件后 agent 会做：
#   1. 把任务详情写到 ~/finance-system-tasks/issue-N.md
#   2. 终端醒目打印 + 桌面通知（macOS 用 osascript）
# 开发者看到通知后，把任务文件丢给 ChatGPT 即可。
#
# 任务文件存放目录（默认 ~/finance-system-tasks）
# TASKS_DIR=/Users/yourname/Desktop/tasks
#
# 是否启用桌面通知（默认 1，0 = 关闭）
# DESKTOP_NOTIFY=1
#
# 如果用 Claude Code CLI 这类支持 -p 模式的工具，可填命令让 agent 自动启动：
# 占位符：{issue_number} {issue_title} {issue_url} {action_hint}
# AGENT_DISPATCH_CMD=claude -p "请完成任务 #{issue_number}：{issue_title}"

# ===== UTF-8 兜底 =====
LANG=en_US.UTF-8
LC_ALL=en_US.UTF-8
PYTHONUTF8=1
PYTHONIOENCODING=utf-8
