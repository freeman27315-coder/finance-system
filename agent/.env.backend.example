GITHUB_TOKEN=ghp_your_token_here
WEBHOOK_SECRET=your_webhook_secret_here
AGENT_LABEL=backend
# gh CLI 完整路径，默认 "gh"；若 which gh 返回非标准路径则填入
# GH_PATH=/Users/yourname/bin/gh
# cloudflared 完整路径，默认 "cloudflared"；若 which cloudflared 找不到则填入
# CLOUDFLARED_PATH=/Users/yourname/bin/cloudflared

# ===== 事件驱动激活方式（Codex AI Agent） =====
# 收到 GitHub 事件后 agent 会做：
#   1. 把任务详情写到 ~/finance-system-tasks/issue-N.md
#   2. 把任务文件路径追加到 ~/finance-system-tasks/inbox.txt
#   3. 终端醒目打印 + macOS 桌面通知
# 你需要在另一个终端窗口运行 ./codex_listener.sh，它会 tail inbox 并把任务喂给 codex
#
# TASKS_DIR=/Users/yourname/Desktop/tasks  # 任务目录（默认 ~/finance-system-tasks）
# INBOX_FILE=...                            # inbox 文件（默认 $TASKS_DIR/inbox.txt）
# DESKTOP_NOTIFY=1                          # 桌面通知（默认 1）
#
# AGENT_DISPATCH_CMD（可选，留空用 inbox 模式）
# 仅当你不想用 codex_listener.sh 而是让 agent 直接 Popen 启动 CLI 时填，例如：
# AGENT_DISPATCH_CMD=claude -p "请完成任务 #{issue_number}：{issue_title}"

# ===== UTF-8 兜底 =====
LANG=en_US.UTF-8
LC_ALL=en_US.UTF-8
PYTHONUTF8=1
PYTHONIOENCODING=utf-8
